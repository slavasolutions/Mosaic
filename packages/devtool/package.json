{
  "name": "@ssolu/mosaic-devtool",
  "version": "0.2.0",
  "description": "Browser-side inspector for Mosaic-rendered pages. Drop-in <script src> reads the resolved record, the raw record, the JSON-LD subset, and the rendered <head>.",
  "type": "module",
  "main": "./dist/esm/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js"
    },
    "./script": {
      "default": "./dist/mosaic-devtool.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/bundle.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mosaic",
    "devtool",
    "inspector",
    "json-ld",
    "browser"
  ],
  "author": "Slava Solutions",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slavasolutions/mosaic.git",
    "directory": "packages/devtool"
  },
  "homepage": "https://github.com/slavasolutions/mosaic/tree/main/packages/devtool#readme",
  "bugs": {
    "url": "https://github.com/slavasolutions/mosaic/issues"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "esbuild": "^0.25.0",
    "jsdom": "^25.0.0",
    "@types/jsdom": "^21.1.7",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
