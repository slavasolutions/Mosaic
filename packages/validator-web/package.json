{
  "name": "@ssolu/mosaic-validator-web",
  "version": "0.1.1",
  "description": "Drop-in browser validator for Mosaic folders. Wraps @ssolu/mosaic-core's pure validateFiles + a drag-and-drop UI.",
  "type": "module",
  "main": "./dist/esm/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js"
    },
    "./script": {
      "default": "./dist/mosaic-validator-web.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/bundle.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mosaic",
    "validator",
    "browser",
    "drag-and-drop"
  ],
  "author": "Slava Solutions",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slavasolutions/mosaic.git",
    "directory": "packages/validator-web"
  },
  "homepage": "https://github.com/slavasolutions/mosaic/tree/main/packages/validator-web#readme",
  "bugs": {
    "url": "https://github.com/slavasolutions/mosaic/issues"
  },
  "dependencies": {
    "@ssolu/mosaic-core": "*"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^25.9.1",
    "esbuild": "^0.25.0",
    "jsdom": "^25.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
