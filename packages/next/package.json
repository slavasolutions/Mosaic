{
  "name": "@ssolu/mosaic-next",
  "version": "0.1.0",
  "description": "Next.js helpers for Mosaic folders. Read your content from a folder; let Next render it. App Router (primary) and Pages Router (fallback).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md",
    "logo.svg"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "mosaic",
    "next",
    "nextjs",
    "content",
    "app-router"
  ],
  "author": "Slava Solutions",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/slavasolutions/mosaic.git",
    "directory": "packages/next"
  },
  "homepage": "https://github.com/slavasolutions/mosaic/tree/main/packages/next",
  "bugs": {
    "url": "https://github.com/slavasolutions/mosaic/issues"
  },
  "dependencies": {
    "@ssolu/mosaic-core": "*"
  },
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": false
    },
    "react": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/react": "^18.3.12",
    "next": "^15.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=20"
  }
}
