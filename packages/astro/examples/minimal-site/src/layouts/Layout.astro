---
const { title, currentPath } = Astro.props as { title: string; currentPath: string };
const base = (import.meta.env.BASE_URL ?? '/').replace(/\/+$/, '');
function href(p: string): string {
  return base + p;
}
const nav = [
  { label: 'Home', url: '/' },
  { label: 'About', url: '/about' },
  { label: 'Blog', url: '/blog' },
];
function isActive(linkUrl: string): boolean {
  if (linkUrl === '/') return currentPath === '/';
  return currentPath === linkUrl || currentPath.startsWith(linkUrl + '/');
}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Acme Foundry</title>
    <style>
      :root {
        --bg: #fafaf7;
        --ink: #15161a;
        --ink-soft: #3a3c44;
        --ink-mute: #6b6e78;
        --line: #e4e2d8;
        --accent: #2b56d4;
        --accent-soft: #e7edff;
        --accent-ink: #1b3aa0;
        --code-bg: #f1f0ea;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0d0f13;
          --ink: #ecedf0;
          --ink-soft: #b8bbc4;
          --ink-mute: #7d818d;
          --line: #23262e;
          --accent: #7da3ff;
          --accent-soft: #182142;
          --accent-ink: #b9cbff;
          --code-bg: #14171c;
        }
      }
      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
        background: var(--bg);
        color: var(--ink);
        line-height: 1.6;
        font-size: 16px;
        -webkit-font-smoothing: antialiased;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      .demo-banner {
        background: var(--accent-soft);
        color: var(--accent-ink);
        padding: 10px 16px;
        font-size: 13px;
        text-align: center;
        border-bottom: 1px solid var(--line);
      }
      .demo-banner code { background: rgba(0,0,0,0.06); padding: 1px 5px; border-radius: 3px; font-size: 12px; }
      @media (prefers-color-scheme: dark) {
        .demo-banner code { background: rgba(255,255,255,0.08); }
      }
      header.site {
        border-bottom: 1px solid var(--line);
      }
      .nav-inner {
        max-width: 720px;
        margin: 0 auto;
        padding: 18px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
      }
      .brand {
        font-family: ui-serif, Georgia, "Times New Roman", serif;
        font-size: 18px;
        font-weight: 500;
        color: var(--ink);
      }
      nav.site-nav { display: flex; gap: 18px; }
      nav.site-nav a {
        color: var(--ink-soft);
        font-size: 14px;
        padding: 6px 0;
      }
      nav.site-nav a.active { color: var(--ink); border-bottom: 2px solid var(--accent); }
      main {
        max-width: 720px;
        margin: 0 auto;
        padding: 32px 20px 60px;
      }
      footer.site {
        max-width: 720px;
        margin: 0 auto;
        padding: 28px 20px 60px;
        border-top: 1px solid var(--line);
        color: var(--ink-mute);
        font-size: 13px;
      }
      footer.site code { background: var(--code-bg); padding: 2px 5px; border-radius: 3px; font-size: 12px; }
      .raw-details {
        margin-top: 56px;
        padding: 14px 16px;
        background: var(--code-bg);
        border: 1px solid var(--line);
        border-radius: 8px;
        font-size: 13px;
      }
      .raw-details summary {
        cursor: pointer;
        color: var(--ink-soft);
        font-family: ui-monospace, "SF Mono", "Menlo", "Consolas", monospace;
        font-size: 12px;
      }
      .raw-details pre {
        margin: 12px 0 0;
        white-space: pre-wrap;
        word-break: break-word;
        font-family: ui-monospace, "SF Mono", "Menlo", "Consolas", monospace;
        font-size: 12px;
        line-height: 1.5;
        color: var(--ink-soft);
      }
      pre.body-block {
        white-space: pre-wrap;
        font-family: inherit;
        color: var(--ink-soft);
        margin: 0;
      }
      .body-block p { margin: 0 0 1em; }
    </style>
  </head>
  <body>
    <div class="demo-banner">
      Demo site — every page on this domain is a JSON file plus optional Markdown in a folder. Astro compiled it to static HTML. <a href="https://github.com/slavasolutions/mosaic">See the spec →</a>
    </div>
    <header class="site">
      <div class="nav-inner">
        <a class="brand" href={href('/')}>Acme Foundry</a>
        <nav class="site-nav">
          {nav.map((item) => (
            <a
              href={href(item.url)}
              class={isActive(item.url) ? 'active' : ''}
            >{item.label}</a>
          ))}
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site">
      Built with <a href="https://astro.build">Astro</a> and the <a href="https://github.com/slavasolutions/mosaic"><code>@ssolu/mosaic-astro</code></a> loader. Each page above is a single static HTML file compiled from a folder of JSON. No runtime, no database, no engine.
    </footer>
  </body>
</html>
