---
import { getCollection } from 'astro:content';
const { title, currentPath, entry } = Astro.props as {
  title: string;
  currentPath: string;
  entry: { id: string; data: Record<string, unknown>; body?: string };
};
const base = (import.meta.env.BASE_URL ?? '/').replace(/\/+$/, '');
function href(p: string): string {
  return base + p;
}
// Banner content comes from a Mosaic record (content/banner.json) outside the
// pages/ profile root — it has no URL but the loader still emits it. This
// dogfoods the "non-route record" pattern from Mosaic Web §4.3.
const all = await getCollection('pages');
const banner = all.find((e) => e.id === 'banner')?.data as
  | { text?: string; linkText?: string; linkUrl?: string }
  | undefined;

const nav = [
  { label: 'Home', url: '/' },
  { label: 'About', url: '/about' },
  { label: 'Blog', url: '/blog' },
];
function isActive(linkUrl: string): boolean {
  if (linkUrl === '/') return currentPath === '/';
  return currentPath === linkUrl || currentPath.startsWith(linkUrl + '/');
}

// Serialize the resolved record for the floating JSON viewer.
const resolvedJson = JSON.stringify(
  {
    id: entry.id,
    url: entry.data.url,
    data: entry.data,
    hasBody: typeof entry.body === 'string' && entry.body.length > 0,
  },
  null,
  2,
);

// === Design tokens (mosaic-design-tokens profile) ============================
// `theme` cascades from the root collection record (content/index.json's
// defaults.theme = "ref:/tokens"). After ref resolution, entry.data.theme
// is the full theme record — read its `tokens` field. Falls back to inline
// defaults if no theme is set.
const themeRecord = entry.data.theme as { tokens?: Record<string, string> } | undefined;
const tok = themeRecord?.tokens ?? {};
function v(key: string, fallback: string): string {
  return tok[key] ?? fallback;
}
const tokenCss = `:root {
  --bg: ${v('color.bg', '#faf6ee')};
  --bg-elev: ${v('color.bg-elev', '#ffffff')};
  --bg-sunk: ${v('color.bg-sunk', '#f2ede1')};
  --ink: ${v('color.ink', '#2a2620')};
  --ink-soft: ${v('color.ink-soft', '#5a544a')};
  --ink-mute: ${v('color.ink-mute', '#8a8278')};
  --line: ${v('color.line', '#e8e0cc')};
  --accent: ${v('color.accent', '#4a9b7a')};
  --accent-soft: ${v('color.accent-soft', '#d6ecdf')};
  --accent-ink: ${v('color.accent-ink', '#2d6b54')};
  --banner-bg: ${v('color.banner-bg', '#fbeec2')};
  --banner-ink: ${v('color.banner-ink', '#6a4d10')};
  --banner-line: ${v('color.banner-line', '#e8d49a')};
}`;

// === JSON-LD (mosaic-web profile §6) =========================================
// Emit a schema.org graph for any record that declares @type. Strip
// Mosaic-internal fields (slug, url, modifiers, theme — all consumer-side
// concerns, not schema.org properties).
const schemaType = entry.data['@type'] as string | undefined;
let jsonLd: string | null = null;
if (schemaType) {
  const { slug, url, modifiers, theme, ...semantic } = entry.data as Record<string, unknown>;
  jsonLd = JSON.stringify(
    {
      '@context': (entry.data['@context'] as string | undefined) ?? 'https://schema.org',
      ...semantic,
    },
    null,
    2,
  );
}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Acme Foundry</title>
    <link rel="icon" type="image/svg+xml" href={href('/logo.svg')} />
    <style>
      :root {
        --bg: #faf6ee;
        --bg-elev: #ffffff;
        --bg-sunk: #f2ede1;
        --ink: #2a2620;
        --ink-soft: #5a544a;
        --ink-mute: #8a8278;
        --line: #e8e0cc;
        --accent: #4a9b7a;
        --accent-soft: #d6ecdf;
        --accent-ink: #2d6b54;
        --warm-yellow: #f5d97c;
        --warm-yellow-soft: #fbeec2;
        --warm-peach: #f4c8a8;
        --warm-blue-soft: #d6e5f2;
        --banner-bg: #fbeec2;
        --banner-ink: #6a4d10;
        --banner-line: #e8d49a;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #15130f;
          --bg-elev: #1e1b15;
          --bg-sunk: #100e0b;
          --ink: #ecead8;
          --ink-soft: #b8b3a0;
          --ink-mute: #7d7868;
          --line: #2a261d;
          --accent: #88c4a8;
          --accent-soft: #1d3329;
          --accent-ink: #b8e0cd;
          --warm-yellow: #c4a652;
          --warm-yellow-soft: #2b240f;
          --warm-peach: #c89a78;
          --warm-blue-soft: #1b2530;
          --banner-bg: #2b240f;
          --banner-ink: #e8d49a;
          --banner-line: #524515;
        }
      }
      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
        background: var(--bg);
        color: var(--ink);
        line-height: 1.6;
        font-size: 16px;
        -webkit-font-smoothing: antialiased;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }

      /* ----- Meta banner — thin single-line strip, scrolls horizontally if narrow ----- */
      .meta-banner {
        background: var(--banner-bg);
        color: var(--banner-ink);
        border-bottom: 1px solid var(--banner-line);
        padding: 0;
        font-size: 13px;
        line-height: 1.4;
        overflow-x: auto;
        overflow-y: hidden;
        white-space: nowrap;
        -webkit-overflow-scrolling: touch;
      }
      .meta-banner-inner {
        display: inline-flex;
        gap: 10px;
        align-items: center;
        padding: 8px 20px;
        white-space: nowrap;
      }
      .meta-banner-label {
        flex-shrink: 0;
        font-family: ui-monospace, "SF Mono", "Menlo", "Consolas", monospace;
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 2px 5px;
        background: rgba(0,0,0,0.08);
        border-radius: 3px;
        line-height: 1.2;
      }
      @media (prefers-color-scheme: dark) {
        .meta-banner-label { background: rgba(255,255,255,0.08); }
      }
      .meta-banner a {
        color: var(--banner-ink);
        text-decoration: underline;
      }

      /* ----- Site header (chrome) ----- */
      header.site {
        background: var(--bg);
        border-bottom: 1px solid var(--line);
      }
      .nav-inner {
        max-width: 720px;
        margin: 0 auto;
        padding: 18px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        font-family: ui-serif, Georgia, "Times New Roman", serif;
        font-size: 18px;
        font-weight: 500;
        color: var(--ink);
      }
      .brand img { width: 28px; height: 28px; display: block; }
      nav.site-nav { display: flex; gap: 18px; }
      nav.site-nav a {
        color: var(--ink-soft);
        font-size: 14px;
        padding: 6px 0;
        min-height: 32px;
        display: inline-flex;
        align-items: center;
      }
      nav.site-nav a.active { color: var(--ink); border-bottom: 2px solid var(--accent); }

      /* ----- Main + footer ----- */
      main {
        max-width: 720px;
        margin: 0 auto;
        padding: 32px 20px 80px;
      }
      footer.site {
        max-width: 720px;
        margin: 0 auto;
        padding: 28px 20px 80px;
        border-top: 1px solid var(--line);
        color: var(--ink-mute);
        font-size: 13px;
      }
      footer.site code { background: var(--bg-sunk); padding: 2px 5px; border-radius: 3px; font-size: 12px; }

      /* ----- Floating "view JSON" button + modal panel ----- */
      .raw-fab {
        position: fixed;
        right: 16px;
        bottom: 16px;
        z-index: 90;
        background: var(--ink);
        color: var(--bg);
        border: none;
        border-radius: 999px;
        padding: 10px 14px;
        font-family: ui-monospace, "SF Mono", "Menlo", "Consolas", monospace;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        box-shadow: 0 4px 14px rgba(0,0,0,0.18);
        display: inline-flex;
        align-items: center;
        gap: 6px;
        min-height: 44px;
      }
      .raw-fab:hover { transform: translateY(-1px); }
      .raw-fab svg { width: 14px; height: 14px; }

      .raw-modal[hidden] { display: none !important; }
      .raw-modal {
        position: fixed;
        inset: 0;
        z-index: 100;
        display: flex;
        justify-content: flex-end;
      }
      .raw-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.35);
        cursor: pointer;
      }
      .raw-panel {
        position: relative;
        width: min(480px, 100vw);
        height: 100vh;
        background: var(--bg-elev);
        border-left: 1px solid var(--line);
        box-shadow: -8px 0 24px rgba(0,0,0,0.15);
        display: flex;
        flex-direction: column;
        animation: slidein 200ms ease-out;
      }
      @keyframes slidein {
        from { transform: translateX(100%); }
        to   { transform: translateX(0); }
      }
      .raw-header {
        flex-shrink: 0;
        padding: 14px 16px;
        border-bottom: 1px solid var(--line);
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .raw-header h2 {
        margin: 0;
        font-family: ui-serif, Georgia, serif;
        font-weight: 500;
        font-size: 16px;
        color: var(--ink);
      }
      .raw-close {
        background: none;
        border: none;
        font-size: 22px;
        line-height: 1;
        color: var(--ink-mute);
        cursor: pointer;
        padding: 6px 10px;
        min-height: 44px;
        min-width: 44px;
      }
      .raw-close:hover { color: var(--ink); }
      .raw-body {
        flex: 1;
        overflow: auto;
        padding: 16px;
      }
      .raw-body pre {
        margin: 0;
        font-family: ui-monospace, "SF Mono", "Menlo", "Consolas", monospace;
        font-size: 12px;
        line-height: 1.55;
        color: var(--ink-soft);
        white-space: pre-wrap;
        word-break: break-word;
      }
      .raw-explain {
        padding: 12px 16px;
        background: var(--bg-sunk);
        border-top: 1px solid var(--line);
        font-size: 12px;
        color: var(--ink-mute);
        line-height: 1.5;
      }
      .raw-explain code {
        background: var(--bg);
        padding: 1px 4px;
        border-radius: 3px;
      }

      @media (max-width: 540px) {
        .raw-panel { width: 100vw; border-left: none; }
        .raw-fab { right: 12px; bottom: 12px; }
      }

      /* ----- Page content elements ----- */
      pre.body-block {
        white-space: pre-wrap;
        font-family: inherit;
        color: var(--ink-soft);
        margin: 0;
      }
      .body-block p { margin: 0 0 1em; }
    </style>
    <style set:html={tokenCss}></style>
    {jsonLd && (
      <script type="application/ld+json" set:html={jsonLd}></script>
    )}
  </head>
  <body>
    {banner && (
      <div class="meta-banner">
        <div class="meta-banner-inner">
          <span class="meta-banner-label">META</span>
          <span>
            {banner.text}{' '}
            {banner.linkUrl && <a href={banner.linkUrl}>{banner.linkText ?? 'Learn more'}</a>}
          </span>
        </div>
      </div>
    )}
    <header class="site">
      <div class="nav-inner">
        <a class="brand" href={href('/')}>
          <img src={href('/logo.svg')} alt="" />
          Acme Foundry
        </a>
        <nav class="site-nav">
          {nav.map((item) => (
            <a
              href={href(item.url)}
              class={isActive(item.url) ? 'active' : ''}
            >{item.label}</a>
          ))}
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site">
      Built with <a href="https://astro.build">Astro</a> and the <a href="https://github.com/slavasolutions/mosaic"><code>@ssolu/mosaic-astro</code></a> loader. Each page is a single static HTML file compiled from a folder of JSON. No runtime, no database, no engine.
    </footer>

    <!-- Floating "view JSON" button (visible on every page) -->
    <button id="raw-fab" class="raw-fab" type="button" aria-label="View the Mosaic-resolved JSON for this page">
      <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M5 2 H3 a1 1 0 0 0 -1 1 V13 a1 1 0 0 0 1 1 H5 M11 2 H13 a1 1 0 0 1 1 1 V13 a1 1 0 0 1 -1 1 H11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
      JSON
    </button>

    <div id="raw-modal" class="raw-modal" hidden>
      <div class="raw-backdrop" data-close></div>
      <div class="raw-panel" role="dialog" aria-modal="true" aria-labelledby="raw-title">
        <div class="raw-header">
          <h2 id="raw-title">Resolved record</h2>
          <button class="raw-close" type="button" data-close aria-label="Close">×</button>
        </div>
        <div class="raw-body">
          <pre>{resolvedJson}</pre>
        </div>
        <div class="raw-explain">
          What you see above is exactly what the Mosaic→Astro pipeline gave this page. Sidecars merged, <code>ref:</code> values resolved, cascade applied — per spec §§5–12.
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        const fab = document.getElementById('raw-fab');
        const modal = document.getElementById('raw-modal');
        if (!fab || !modal) return;
        function open() { modal.hidden = false; document.body.style.overflow = 'hidden'; }
        function close() { modal.hidden = true; document.body.style.overflow = ''; }
        fab.addEventListener('click', open);
        modal.addEventListener('click', function (e) {
          if (e.target && e.target.dataset && e.target.dataset.close !== undefined) close();
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && !modal.hidden) close();
        });
      })();
    </script>
  </body>
</html>
