---
import { getCollection } from 'astro:content';
import { fileURLToPath } from 'node:url';
import { buildTree, toTreePath } from '../lib/tree';
const { title, currentPath, entry } = Astro.props as {
  title: string;
  currentPath: string;
  entry: { id: string; data: Record<string, unknown>; body?: string; filePath?: string };
};
const base = (import.meta.env.BASE_URL ?? '/').replace(/\/+$/, '');
function href(p: string): string {
  return base + p;
}

// === Site chrome — banner + nav + footer read from non-route records ========
// Banner: `<root>/banner.json`. Nav: index collection record's `nav` field
// (under `defaults`-style root config). Footer columns: same record's
// `footer` field. Any of these may be absent — the layout degrades to a
// minimal chrome (single shape has no banner, no footer columns, no nav).
const all = await getCollection('pages');
const banner = all.find((e) => e.id === 'banner')?.data as
  | { text?: string; linkText?: string; linkUrl?: string }
  | undefined;

// `id === ''` is the root collection record (mosaic.json + root index.json).
// Loader emits it with id 'index' in some shapes; we look at both.
const rootRecord =
  (all.find((e) => e.id === 'index') ??
    all.find((e) => e.id === ''))?.data as
    | {
        nav?: Array<{ label: string; url: string }>;
        footer?: {
          tagline?: string;
          address?: string;
          email?: string;
          columns?: Array<{
            heading?: string;
            links?: Array<{ label: string; url: string }>;
          }>;
        };
      }
    | undefined;

const navItems: Array<{ label: string; url: string }> = rootRecord?.nav ?? [];
const footer = rootRecord?.footer;

function isActive(linkUrl: string): boolean {
  if (linkUrl === '/') return currentPath === '/';
  return currentPath === linkUrl || currentPath.startsWith(linkUrl + '/');
}

// === Locale switcher ========================================================
// The Astro loader emits Path A variants as separate entries with id
// `<identity>::<modifiers.join('.')>` (canonical entries keep the bare
// identity). The current entry's identity sits in `entry.data.slug`; we
// look for a sibling entry whose modifiers include 'fr'.
const currentSlug = (entry.data as any).slug as string | undefined;
const currentModifiers = ((entry.data as any).modifiers ?? []) as string[];
const isFrenchVariant = currentModifiers.includes('fr');
const hasFrenchVariant = currentSlug
  ? all.some((e) => {
      const d = e.data as any;
      return d.slug === currentSlug && Array.isArray(d.modifiers) && d.modifiers.includes('fr');
    })
  : false;
const showLocaleSwitcher = hasFrenchVariant || isFrenchVariant;

// Serialise the resolved record so @ssolu/mosaic-devtool can find it in the
// page when the inspector mounts. The devtool reads
// `<script type="application/json" id="mosaic-record">` from <head>.
const resolvedJson = JSON.stringify(
  {
    id: entry.id,
    url: entry.data.url,
    data: entry.data,
    hasBody: typeof entry.body === 'string' && entry.body.length > 0,
  },
  null,
  2,
);

// Devtool loads on every page (set `?nodebug=1` on the URL to suppress).
// The script lives at <pages-root>/_mosaic-devtool/mosaic-devtool.js —
// sibling to the deploy slots so all six adapter sites share one copy.
const isDeploy = import.meta.env.GITHUB_PAGES_DEPLOY === '1' || process.env.GITHUB_PAGES_DEPLOY === '1';
const devtoolSrc = isDeploy
  ? '/_mosaic-devtool/mosaic-devtool.js'
  : '/_mosaic-devtool/mosaic-devtool.js';

// === File tree (devtool Tree tab) ============================================
// Walks the active content folder at SSG and emits the flat shape devtool's
// tree.ts accepts. Matrix variants drive `MOSAIC_CONTENT_DIR` to point at
// content-single / content-blog / content-full.
const contentDir = process.env.MOSAIC_CONTENT_DIR ?? 'content';
const contentRoot = fileURLToPath(new URL(`../../../../../../examples/${contentDir}/`, import.meta.url));
const treePayload = buildTree(contentRoot, contentDir);
if (entry.filePath) {
  const ap = toTreePath(entry.filePath, contentRoot);
  if (ap) treePayload.activePath = ap;
}
const treeJson = JSON.stringify(treePayload);

// === Devtool site list — adapter switcher entries ===========================
// Emits an `id="mosaic-sites"` payload that overrides the devtool's
// hardcoded default list with this deploy's matrix. The shape × adapter URL
// matrix is the same on every page; the devtool highlights whichever entry
// matches the current pathname.
const SITE_LIST = JSON.stringify([
  { label: 'Single · Astro', url: '/demo-single/', note: '1 page' },
  { label: 'Single · Next', url: '/demo-single-next/', note: '1 page' },
  { label: 'Blog · Astro', url: '/demo-blog/', note: '3 pages + journal' },
  { label: 'Blog · Next', url: '/demo-blog-next/', note: '3 pages + journal' },
  { label: 'Full · Astro', url: '/demo-full/', note: '12+ pages, nav, sub-pages' },
  { label: 'Full · Next', url: '/demo-full-next/', note: '12+ pages, nav, sub-pages' },
]);

// === Design tokens (mosaic-design-tokens profile) ============================
// `theme` cascades from the root collection record's `defaults.theme`.
// After ref resolution, entry.data.theme is the full theme record — read
// its `tokens` field. Falls back to inline defaults if no theme is set.
const themeRecord = entry.data.theme as { tokens?: Record<string, string> } | undefined;
const tok = themeRecord?.tokens ?? {};
function v(key: string, fallback: string): string {
  return tok[key] ?? fallback;
}
// Light + dark token blocks. The dark side reuses the same keys; if a
// folder doesn't ship a dark variant we use the embedded fallback. The
// user can switch via the footer toggle (data-theme on <html>); without
// an override prefers-color-scheme picks.
const lightTokenCss = `:root {
  --bg: ${v('color.bg', '#F5F2EA')};
  --bg-elev: ${v('color.bg-elev', '#FFFFFF')};
  --bg-sunk: ${v('color.bg-sunk', '#EFEBDF')};
  --ink: ${v('color.ink', '#2A2A24')};
  --ink-soft: ${v('color.ink-soft', '#4A4A40')};
  --ink-mute: ${v('color.ink-mute', '#7B776C')};
  --line: ${v('color.line', '#E0DCC9')};
  --accent: ${v('color.accent', '#7B86D6')};
  --accent-soft: ${v('color.accent-soft', '#ECEEF9')};
  --accent-ink: ${v('color.accent-ink', '#4853A8')};
  --banner-bg: ${v('color.banner-bg', '#F4D58D')};
  --banner-ink: ${v('color.banner-ink', '#5A4A1A')};
  --banner-line: ${v('color.banner-line', '#D9B85F')};
  --font-body: ${v('font.body', '"Instrument Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif')};
  --font-serif: ${v('font.serif', '"Spectral", ui-serif, Georgia, "Times New Roman", serif')};
  --font-mono: ${v('font.mono', '"JetBrains Mono", ui-monospace, "SF Mono", "Menlo", "Consolas", monospace')};
  --radius-md: ${v('radius.md', '8px')};
}`;

// === JSON-LD (mosaic-web profile §6) =========================================
const schemaType = entry.data['@type'] as string | undefined;
let jsonLd: string | null = null;
if (schemaType) {
  const { slug, url, modifiers, theme, ...semantic } = entry.data as Record<string, unknown>;
  jsonLd = JSON.stringify(
    {
      '@context': (entry.data['@context'] as string | undefined) ?? 'https://schema.org',
      ...semantic,
    },
    null,
    2,
  );
}

// === Locale-switcher hrefs ==================================================
// For the home/about pair we already know the variant lives at
// `<id>.fr`. The route URL stays the same (sidecars share identity); we
// keep the switcher informational for v1 and just toggle visibility.
// Future work could route fr variants under `/fr/...`.
---
<!doctype html>
<html lang={isFrenchVariant ? 'fr' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={href('/logo.svg')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,400;0,500;0,600;1,400&family=Instrument+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --bg: #F5F2EA;
        --bg-elev: #FFFFFF;
        --bg-sunk: #EFEBDF;
        --ink: #2A2A24;
        --ink-soft: #4A4A40;
        --ink-mute: #7B776C;
        --line: #E0DCC9;
        --accent: #7B86D6;
        --accent-soft: #ECEEF9;
        --accent-ink: #4853A8;
        --banner-bg: #F4D58D;
        --banner-ink: #5A4A1A;
        --banner-line: #D9B85F;
        --font-body: "Instrument Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
        --font-serif: "Spectral", ui-serif, Georgia, "Times New Roman", serif;
        --font-mono: "JetBrains Mono", ui-monospace, "SF Mono", "Menlo", "Consolas", monospace;
        --radius-md: 8px;
      }
      /* OS-preference fallback. User pick via data-theme on <html> wins,
         see `html[data-theme="dark"]` block below. */
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #1A1A1F;
          --bg-elev: #232329;
          --bg-sunk: #14141A;
          --ink: #ECEAE0;
          --ink-soft: #BCB8AC;
          --ink-mute: #7A776C;
          --line: #2E2E36;
          --accent: #9CA6E2;
          --accent-soft: #2A2D52;
          --accent-ink: #C5CCEC;
          --banner-bg: #2E2410;
          --banner-ink: #F4D58D;
          --banner-line: #5A4A1A;
        }
      }
      /* User-picked dark — overrides OS pref. */
      html[data-theme="dark"] {
        --bg: #1A1A1F;
        --bg-elev: #232329;
        --bg-sunk: #14141A;
        --ink: #ECEAE0;
        --ink-soft: #BCB8AC;
        --ink-mute: #7A776C;
        --line: #2E2E36;
        --accent: #9CA6E2;
        --accent-soft: #2A2D52;
        --accent-ink: #C5CCEC;
        --banner-bg: #2E2410;
        --banner-ink: #F4D58D;
        --banner-line: #5A4A1A;
      }
      /* User-picked light — overrides OS pref. */
      html[data-theme="light"] {
        --bg: #F5F2EA;
        --bg-elev: #FFFFFF;
        --bg-sunk: #EFEBDF;
        --ink: #2A2A24;
        --ink-soft: #4A4A40;
        --ink-mute: #7B776C;
        --line: #E0DCC9;
        --accent: #7B86D6;
        --accent-soft: #ECEEF9;
        --accent-ink: #4853A8;
        --banner-bg: #F4D58D;
        --banner-ink: #5A4A1A;
        --banner-line: #D9B85F;
      }
      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      html { scrollbar-gutter: stable; }
      body {
        font-family: var(--font-body, "Instrument Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif);
        background: var(--bg);
        color: var(--ink);
        line-height: 1.6;
        font-size: 16px;
        -webkit-font-smoothing: antialiased;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }

      /* ----- Meta banner ----- */
      .meta-banner {
        background: var(--banner-bg);
        color: var(--banner-ink);
        border-bottom: 1px solid var(--banner-line);
        font-size: 13px;
        line-height: 1.4;
        overflow-x: auto;
        white-space: nowrap;
        text-align: center;
      }
      .meta-banner-inner {
        display: inline-flex;
        gap: 10px;
        align-items: center;
        padding: 8px 20px;
        max-width: 1240px;
        margin: 0 auto;
      }
      .meta-banner-label {
        flex-shrink: 0;
        font-family: var(--font-mono);
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 2px 5px;
        background: rgba(0,0,0,0.08);
        border-radius: 3px;
      }
      @media (prefers-color-scheme: dark) { .meta-banner-label { background: rgba(255,255,255,0.08); } }
      html[data-theme="dark"] .meta-banner-label { background: rgba(255,255,255,0.08); }
      .meta-banner a { color: var(--banner-ink); text-decoration: underline; }

      /* ----- Site header (chrome) ----- */
      header.site { background: var(--bg); border-bottom: 1px solid var(--line); }
      .nav-inner {
        max-width: 1240px;
        margin: 0 auto;
        padding: 18px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        font-family: var(--font-serif);
        font-size: 18px;
        font-weight: 500;
        color: var(--ink);
      }
      .brand img { width: 28px; height: 28px; display: block; }
      nav.site-nav { display: flex; gap: 18px; flex-wrap: wrap; }
      nav.site-nav a {
        color: var(--ink-soft);
        font-size: 14px;
        padding: 6px 0;
        min-height: 32px;
        display: inline-flex;
        align-items: center;
      }
      nav.site-nav a.active { color: var(--ink); border-bottom: 2px solid var(--accent); }

      /* ----- Locale switcher (header right) ----- */
      .locale-switch {
        display: inline-flex;
        gap: 4px;
        align-items: center;
        padding: 3px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: var(--bg-elev);
        font-family: var(--font-mono);
        font-size: 11px;
      }
      .locale-switch a {
        padding: 4px 10px;
        border-radius: 999px;
        color: var(--ink-mute);
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        min-height: 24px;
        display: inline-flex;
        align-items: center;
      }
      .locale-switch a:hover { color: var(--ink); background: var(--bg-sunk); text-decoration: none; }
      .locale-switch a[aria-current="page"] { color: var(--ink); background: var(--accent-soft); cursor: default; }

      /* ----- Main ----- */
      main {
        flex: 1;
        max-width: 1240px;
        margin: 0 auto;
        width: 100%;
        padding: 32px 20px 80px;
      }

      /* ----- Footer ----- */
      footer.site {
        border-top: 1px solid var(--line);
        background: var(--bg-sunk);
        color: var(--ink-mute);
        font-size: 13px;
      }
      .footer-inner {
        max-width: 1240px;
        margin: 0 auto;
        padding: 36px 20px;
        display: grid;
        grid-template-columns: 1fr;
        gap: 28px;
      }
      @media (min-width: 720px) {
        .footer-inner { grid-template-columns: 1.4fr repeat(3, 1fr); }
      }
      .footer-col h4 {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--ink);
        margin: 0 0 12px;
      }
      .footer-col ul { list-style: none; margin: 0; padding: 0; }
      .footer-col li { margin: 0 0 6px; }
      .footer-col a { color: var(--ink-soft); }
      .footer-tagline { color: var(--ink-soft); font-size: 14px; margin: 0 0 8px; }
      .footer-meta { font-size: 12px; }
      .footer-meta div { margin: 0 0 4px; }
      .footer-bottom {
        border-top: 1px solid var(--line);
        background: var(--bg-sunk);
        font-size: 12px;
        color: var(--ink-mute);
      }
      .footer-bottom-inner {
        max-width: 1240px;
        margin: 0 auto;
        padding: 14px 20px;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }
      .footer-bottom code { background: var(--bg); padding: 2px 5px; border-radius: 3px; font-size: 11px; }

      /* ----- Theme switcher (footer) ----- */
      .theme-switch {
        display: inline-flex;
        gap: 2px;
        align-items: center;
        padding: 3px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: var(--bg-elev);
        font-family: var(--font-mono);
        font-size: 11px;
      }
      .theme-switch button {
        padding: 4px 10px;
        border: none;
        background: none;
        border-radius: 999px;
        color: var(--ink-mute);
        cursor: pointer;
        min-height: 24px;
        font: inherit;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      .theme-switch button:hover { color: var(--ink); background: var(--bg-sunk); }
      .theme-switch button[aria-pressed="true"] { color: var(--ink); background: var(--accent-soft); }

      /* ----- Page content elements (rendered markdown) ----- */
      .body-block { color: var(--ink-soft); }
      .body-block p { margin: 0 0 1em; }
      .body-block h2 {
        font-family: var(--font-serif);
        font-size: 22px;
        color: var(--ink);
        margin: 32px 0 12px;
        line-height: 1.25;
      }
      .body-block h3 {
        font-family: var(--font-serif);
        font-size: 18px;
        color: var(--ink);
        margin: 24px 0 10px;
        line-height: 1.3;
      }
      .body-block ul, .body-block ol { margin: 0 0 1em 1.25em; padding: 0; }
      .body-block li { margin: 0 0 0.35em; }
      .body-block blockquote {
        margin: 1em 0;
        padding: 0 0 0 14px;
        border-left: 3px solid var(--accent);
        color: var(--ink-mute);
        font-style: italic;
      }
      .body-block blockquote p { margin: 0 0 0.5em; }
      .body-block blockquote p:last-child { margin-bottom: 0; }
      .body-block code {
        font-family: var(--font-mono);
        font-size: 0.9em;
        background: var(--bg-sunk);
        padding: 1px 5px;
        border-radius: 3px;
      }
      .body-block pre {
        margin: 1em 0;
        padding: 14px 16px;
        background: var(--bg-sunk);
        border: 1px solid var(--line);
        border-radius: 6px;
        overflow-x: auto;
        font-size: 13px;
        line-height: 1.5;
      }
      .body-block pre code { background: none; padding: 0; font-size: inherit; }
      .body-block table {
        border-collapse: collapse;
        margin: 1em 0;
        font-size: 14px;
        width: 100%;
      }
      .body-block th, .body-block td {
        text-align: left;
        padding: 6px 12px;
        border-bottom: 1px solid var(--line);
      }
      .body-block th { color: var(--ink); font-weight: 600; }
      .body-block strong { color: var(--ink); }
      .body-block em { font-style: italic; }
      .body-block a { color: var(--accent); }
      .body-block img { max-width: 100%; height: auto; border-radius: 6px; margin: 1em 0; }

      /* ----- Home / page / post helpers ----- */
      .home-h1 {
        font-family: var(--font-serif);
        font-size: clamp(28px, 4vw, 44px);
        line-height: 1.15;
        letter-spacing: -0.01em;
        margin: 0 0 12px;
      }
      .home-tagline { font-size: 18px; color: var(--ink-soft); margin: 0 0 24px; }
      .hero-img { width: 100%; border-radius: 8px; margin: 0 0 28px; aspect-ratio: 16/7; object-fit: cover; }
      .home-cards {
        list-style: none;
        padding: 0;
        margin: 28px 0 0;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }
      .home-card-link {
        display: inline-block;
        padding: 9px 16px;
        border: 1px solid var(--line);
        border-radius: 8px;
        color: var(--ink);
      }
      .featured-grid {
        list-style: none;
        padding: 0;
        margin: 36px 0 0;
        display: grid;
        grid-template-columns: 1fr;
        gap: 18px;
      }
      @media (min-width: 720px) { .featured-grid { grid-template-columns: repeat(3, 1fr); } }
      .featured-card {
        display: flex;
        flex-direction: column;
        border: 1px solid var(--line);
        border-radius: 8px;
        overflow: hidden;
        background: var(--bg-elev);
        color: var(--ink);
        text-decoration: none;
      }
      .featured-card img { width: 100%; aspect-ratio: 16/10; object-fit: cover; display: block; }
      .featured-card-body { padding: 14px 16px 18px; }
      .featured-card h3 { font-family: var(--font-serif); margin: 0 0 6px; font-size: 18px; }
      .featured-card p { margin: 0; font-size: 14px; color: var(--ink-soft); }

      .page-h1 {
        font-family: var(--font-serif);
        font-size: clamp(26px, 3.5vw, 36px);
        line-height: 1.2;
        margin: 0 0 12px;
      }
      .page-lede { font-size: 17px; color: var(--ink-soft); margin: 0 0 28px; }

      .subpage-grid {
        list-style: none;
        padding: 0;
        margin: 28px 0 0;
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
      }
      @media (min-width: 540px) { .subpage-grid { grid-template-columns: repeat(2, 1fr); } }
      .subpage-grid a {
        display: block;
        padding: 14px 16px;
        border: 1px solid var(--line);
        border-radius: 8px;
        color: var(--ink);
      }
      .subpage-grid a:hover { border-color: var(--accent); text-decoration: none; }

      .post-meta {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--ink-mute);
        font-size: 14px;
        margin: 0 0 28px;
      }
      .post-meta .avatar { flex-shrink: 0; }
      .post-author-card {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        margin-top: 36px;
        padding: 16px;
        background: var(--bg-sunk);
        border-radius: 8px;
        font-size: 14px;
        color: var(--ink-soft);
      }
      .post-author-card .avatar { flex-shrink: 0; }
      .post-author-card .body { flex: 1; min-width: 0; }
      .post-author-card strong { color: var(--ink); }

      .blog-list { list-style: none; padding: 0; margin: 24px 0 0; }
      .blog-list li { padding: 14px 0; border-top: 1px solid var(--line); display: flex; align-items: center; gap: 12px; }
      .blog-list a { display: block; font-size: 17px; color: var(--ink); }
      .blog-list .meta { color: var(--ink-mute); font-size: 13px; margin-top: 4px; }
      .blog-list .avatar { flex-shrink: 0; }
      .blog-list .post-item-text { flex: 1; min-width: 0; }

      .avatar { display: block; border-radius: 50%; }
    </style>
    <style set:html={lightTokenCss}></style>
    {jsonLd && (
      <script type="application/ld+json" set:html={jsonLd}></script>
    )}
    <script type="application/json" id="mosaic-record" set:html={resolvedJson}></script>
    <script type="application/json" id="mosaic-tree" is:inline set:html={treeJson}></script>
    <script type="application/json" id="mosaic-sites" set:html={SITE_LIST}></script>

    <!-- Theme bootstrap — runs before <body> paints to avoid a flash. Reads
         localStorage; writes data-theme on <html> if a saved pick exists. -->
    <script is:inline>
      (function () {
        try {
          var pick = localStorage.getItem('mosaic-theme');
          if (pick === 'light' || pick === 'dark') {
            document.documentElement.setAttribute('data-theme', pick);
          }
        } catch (e) { /* private mode etc — silently fall back to OS pref */ }
      })();
    </script>
  </head>
  <body>
    {banner && (
      <div class="meta-banner">
        <div class="meta-banner-inner">
          <span class="meta-banner-label">META</span>
          <span>
            {banner.text}{' '}
            {banner.linkUrl && <a href={banner.linkUrl}>{banner.linkText ?? 'Learn more'}</a>}
          </span>
        </div>
      </div>
    )}
    <header class="site">
      <div class="nav-inner">
        <a class="brand" href={href('/')}>
          <img src={href('/logo.svg')} alt="" />
          {title.split(' — ')[0] || 'Mosaic'}
        </a>
        {navItems.length > 0 && (
          <nav class="site-nav">
            {navItems.map((item) => (
              <a
                href={href(item.url)}
                class={isActive(item.url) ? 'active' : ''}
              >{item.label}</a>
            ))}
          </nav>
        )}
        {showLocaleSwitcher && (
          <div class="locale-switch" role="group" aria-label="Switch language">
            <a
              href={href(isFrenchVariant
                ? (currentPath || '/')
                : (currentPath || '/'))}
              aria-current={!isFrenchVariant ? 'page' : undefined}
            >EN</a>
            <a
              href={href(currentPath || '/')}
              aria-current={isFrenchVariant ? 'page' : undefined}
              data-locale="fr"
            >FR</a>
          </div>
        )}
      </div>
    </header>
    <main>
      <slot />
    </main>

    <footer class="site">
      {footer && (footer.columns?.length || footer.tagline || footer.email) && (
        <div class="footer-inner">
          <div class="footer-col">
            {footer.tagline && <p class="footer-tagline">{footer.tagline}</p>}
            <div class="footer-meta">
              {footer.address && <div>{footer.address}</div>}
              {footer.email && <div><a href={`mailto:${footer.email}`}>{footer.email}</a></div>}
            </div>
          </div>
          {(footer.columns ?? []).map((col) => (
            <div class="footer-col">
              {col.heading && <h4>{col.heading}</h4>}
              <ul>
                {(col.links ?? []).map((l) => (
                  <li><a href={href(l.url)}>{l.label}</a></li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      )}
      <div class="footer-bottom">
        <div class="footer-bottom-inner">
          <span>
            Built with <a href="https://astro.build">Astro</a> and{' '}
            <a href="https://github.com/slavasolutions/mosaic"><code>@ssolu/mosaic-astro</code></a>.
            Every page is a JSON file in a folder.
          </span>
          <div class="theme-switch" role="group" aria-label="Theme">
            <button type="button" data-theme-set="light" aria-pressed="false">Light</button>
            <button type="button" data-theme-set="dark" aria-pressed="false">Dark</button>
            <button type="button" data-theme-set="system" aria-pressed="false">System</button>
          </div>
        </div>
      </div>
    </footer>

    <!-- Theme switcher runtime. Reads the buttons, swaps data-theme on
         <html>, persists in localStorage. Independent of the head bootstrap
         so the buttons reflect saved state on hydrate. -->
    <script is:inline>
      (function () {
        var buttons = document.querySelectorAll('[data-theme-set]');
        function current() {
          try { return localStorage.getItem('mosaic-theme') || 'system'; }
          catch (e) { return 'system'; }
        }
        function paint() {
          var c = current();
          buttons.forEach(function (b) {
            b.setAttribute('aria-pressed', b.getAttribute('data-theme-set') === c ? 'true' : 'false');
          });
        }
        function apply(p) {
          if (p === 'light' || p === 'dark') {
            document.documentElement.setAttribute('data-theme', p);
          } else {
            document.documentElement.removeAttribute('data-theme');
          }
        }
        buttons.forEach(function (b) {
          b.addEventListener('click', function () {
            var pick = b.getAttribute('data-theme-set');
            try {
              if (pick === 'system') localStorage.removeItem('mosaic-theme');
              else localStorage.setItem('mosaic-theme', pick);
            } catch (e) { /* ignore */ }
            apply(pick);
            paint();
          });
        });
        paint();
      })();
    </script>

    <!-- Studio bridge — listens for postMessage from the /explore/ playground
         so a parent iframe can drive theme + token values live. No effect
         when the page is opened directly (no parent posting messages). -->
    <script is:inline>
      (function () {
        // map editor token keys → CSS custom-property names in this layout
        var TOKEN_TO_CSS = {
          'color.bg':       '--bg',
          'color.ink':      '--ink',
          'color.accent':   '--accent',
          'color.bg-sunk':  '--bg-sunk',
          'color.bg-elev':  '--bg-elev',
          'color.line':     '--line',
          'color.ink-soft': '--ink-soft',
          'color.ink-mute': '--ink-mute',
          'radius.md':      '--radius-md',
        };
        window.addEventListener('message', function (ev) {
          var data = ev && ev.data;
          if (!data || typeof data !== 'object') return;
          if (data.type === 'mosaic-theme') {
            var p = data.theme;
            if (p === 'light' || p === 'dark') {
              document.documentElement.setAttribute('data-theme', p);
            } else {
              document.documentElement.removeAttribute('data-theme');
            }
          }
          if (data.type === 'mosaic-tokens' && data.tokens) {
            Object.keys(data.tokens).forEach(function (k) {
              var cssVar = TOKEN_TO_CSS[k];
              if (cssVar) {
                document.documentElement.style.setProperty(cssVar, data.tokens[k]);
              }
            });
          }
        });
      })();
    </script>

    <!-- @ssolu/mosaic-devtool inspector — loaded on every render.
         Append `?nodebug=1` to any URL to suppress. Suppressed automatically
         inside the Studio iframe to avoid duplicate panels. -->
    <script is:inline define:vars={{ devtoolSrc }}>
      (function () {
        if (location.search.indexOf('nodebug=1') !== -1) return;
        if (window.top !== window.self) return; // inside an iframe (Studio)
        var s = document.createElement('script');
        s.src = devtoolSrc;
        s.defer = true;
        document.head.appendChild(s);
      })();
    </script>
  </body>
</html>
