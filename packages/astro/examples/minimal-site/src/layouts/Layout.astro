---
import { getCollection } from 'astro:content';
import { fileURLToPath } from 'node:url';
import { buildTree, toTreePath } from '../lib/tree';
const { title, currentPath, entry } = Astro.props as {
  title: string;
  currentPath: string;
  entry: { id: string; data: Record<string, unknown>; body?: string; filePath?: string };
};
const base = (import.meta.env.BASE_URL ?? '/').replace(/\/+$/, '');
function href(p: string): string {
  return base + p;
}
// Banner content comes from a Mosaic record (content/banner.json) outside the
// pages/ profile root — it has no URL but the loader still emits it. This
// dogfoods the "non-route record" pattern from Mosaic Web §4.3.
const all = await getCollection('pages');
const banner = all.find((e) => e.id === 'banner')?.data as
  | { text?: string; linkText?: string; linkUrl?: string }
  | undefined;

const nav = [
  { label: 'Home', url: '/' },
  { label: 'About', url: '/about' },
  { label: 'Blog', url: '/blog' },
  { label: 'Legal', url: '/legal' },
];
function isActive(linkUrl: string): boolean {
  if (linkUrl === '/') return currentPath === '/';
  return currentPath === linkUrl || currentPath.startsWith(linkUrl + '/');
}

// Serialise the resolved record so @ssolu/mosaic-devtool can find it in the
// page when the inspector mounts. The devtool reads
// `<script type="application/json" id="mosaic-record">` from <head>.
const resolvedJson = JSON.stringify(
  {
    id: entry.id,
    url: entry.data.url,
    data: entry.data,
    hasBody: typeof entry.body === 'string' && entry.body.length > 0,
  },
  null,
  2,
);

// Devtool loads only when ?debug=1 is in the URL (dev override too). The
// script lives at <pages-root>/_mosaic-devtool/mosaic-devtool.js — sibling
// to `/example/` and `/next-example/` so both adapter sites share one copy.
const isDeploy = import.meta.env.GITHUB_PAGES_DEPLOY === '1' || process.env.GITHUB_PAGES_DEPLOY === '1';
const devtoolSrc = isDeploy
  ? '/mosaic/_mosaic-devtool/mosaic-devtool.js'
  : '/_mosaic-devtool/mosaic-devtool.js';

// === File tree (devtool Tree tab) ============================================
// Walks examples/content/ at SSG and emits the flat shape devtool's
// tree.ts accepts. activePath is the canonical source file (entry.filePath)
// for the record being rendered. Devtool hides the tab when the script is
// absent, so emitting it unconditionally is fine.
const contentRoot = fileURLToPath(new URL('../../../../../../examples/content/', import.meta.url));
const treePayload = buildTree(contentRoot, 'content');
if (entry.filePath) {
  const ap = toTreePath(entry.filePath, contentRoot);
  if (ap) treePayload.activePath = ap;
}
const treeJson = JSON.stringify(treePayload);

// === Design tokens (mosaic-design-tokens profile) ============================
// `theme` cascades from the root collection record (content/index.json's
// defaults.theme = "ref:/tokens"). After ref resolution, entry.data.theme
// is the full theme record — read its `tokens` field. Falls back to inline
// defaults if no theme is set.
const themeRecord = entry.data.theme as { tokens?: Record<string, string> } | undefined;
const tok = themeRecord?.tokens ?? {};
function v(key: string, fallback: string): string {
  return tok[key] ?? fallback;
}
const tokenCss = `:root {
  --bg: ${v('color.bg', '#faf6ee')};
  --bg-elev: ${v('color.bg-elev', '#ffffff')};
  --bg-sunk: ${v('color.bg-sunk', '#f2ede1')};
  --ink: ${v('color.ink', '#2a2620')};
  --ink-soft: ${v('color.ink-soft', '#5a544a')};
  --ink-mute: ${v('color.ink-mute', '#8a8278')};
  --line: ${v('color.line', '#e8e0cc')};
  --accent: ${v('color.accent', '#4a9b7a')};
  --accent-soft: ${v('color.accent-soft', '#d6ecdf')};
  --accent-ink: ${v('color.accent-ink', '#2d6b54')};
  --banner-bg: ${v('color.banner-bg', '#fbeec2')};
  --banner-ink: ${v('color.banner-ink', '#6a4d10')};
  --banner-line: ${v('color.banner-line', '#e8d49a')};
}`;

// === JSON-LD (mosaic-web profile §6) =========================================
// Emit a schema.org graph for any record that declares @type. Strip
// Mosaic-internal fields (slug, url, modifiers, theme — all consumer-side
// concerns, not schema.org properties).
const schemaType = entry.data['@type'] as string | undefined;
let jsonLd: string | null = null;
if (schemaType) {
  const { slug, url, modifiers, theme, ...semantic } = entry.data as Record<string, unknown>;
  jsonLd = JSON.stringify(
    {
      '@context': (entry.data['@context'] as string | undefined) ?? 'https://schema.org',
      ...semantic,
    },
    null,
    2,
  );
}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Acme Foundry</title>
    <link rel="icon" type="image/svg+xml" href={href('/logo.svg')} />
    <style>
      :root {
        --bg: #faf6ee;
        --bg-elev: #ffffff;
        --bg-sunk: #f2ede1;
        --ink: #2a2620;
        --ink-soft: #5a544a;
        --ink-mute: #8a8278;
        --line: #e8e0cc;
        --accent: #4a9b7a;
        --accent-soft: #d6ecdf;
        --accent-ink: #2d6b54;
        --warm-yellow: #f5d97c;
        --warm-yellow-soft: #fbeec2;
        --warm-peach: #f4c8a8;
        --warm-blue-soft: #d6e5f2;
        --banner-bg: #fbeec2;
        --banner-ink: #6a4d10;
        --banner-line: #e8d49a;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #15130f;
          --bg-elev: #1e1b15;
          --bg-sunk: #100e0b;
          --ink: #ecead8;
          --ink-soft: #b8b3a0;
          --ink-mute: #7d7868;
          --line: #2a261d;
          --accent: #88c4a8;
          --accent-soft: #1d3329;
          --accent-ink: #b8e0cd;
          --warm-yellow: #c4a652;
          --warm-yellow-soft: #2b240f;
          --warm-peach: #c89a78;
          --warm-blue-soft: #1b2530;
          --banner-bg: #2b240f;
          --banner-ink: #e8d49a;
          --banner-line: #524515;
        }
      }
      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      html { scrollbar-gutter: stable; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
        background: var(--bg);
        color: var(--ink);
        line-height: 1.6;
        font-size: 16px;
        -webkit-font-smoothing: antialiased;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }

      /* ----- Meta banner — thin centred strip, scrolls horizontally if narrow ----- */
      .meta-banner {
        background: var(--banner-bg);
        color: var(--banner-ink);
        border-bottom: 1px solid var(--banner-line);
        padding: 0;
        font-size: 13px;
        line-height: 1.4;
        overflow-x: auto;
        overflow-y: hidden;
        white-space: nowrap;
        -webkit-overflow-scrolling: touch;
        text-align: center;
      }
      .meta-banner-inner {
        display: inline-flex;
        gap: 10px;
        align-items: center;
        padding: 8px 20px;
        white-space: nowrap;
        max-width: 1240px;
        margin: 0 auto;
      }
      .meta-banner-label {
        flex-shrink: 0;
        font-family: ui-monospace, "SF Mono", "Menlo", "Consolas", monospace;
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 2px 5px;
        background: rgba(0,0,0,0.08);
        border-radius: 3px;
        line-height: 1.2;
      }
      @media (prefers-color-scheme: dark) {
        .meta-banner-label { background: rgba(255,255,255,0.08); }
      }
      .meta-banner a {
        color: var(--banner-ink);
        text-decoration: underline;
      }

      /* ----- Site header (chrome) ----- */
      header.site {
        background: var(--bg);
        border-bottom: 1px solid var(--line);
      }
      .nav-inner {
        max-width: 1240px;
        margin: 0 auto;
        padding: 18px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        font-family: ui-serif, Georgia, "Times New Roman", serif;
        font-size: 18px;
        font-weight: 500;
        color: var(--ink);
      }
      .brand img { width: 28px; height: 28px; display: block; }
      nav.site-nav { display: flex; gap: 18px; }
      nav.site-nav a {
        color: var(--ink-soft);
        font-size: 14px;
        padding: 6px 0;
        min-height: 32px;
        display: inline-flex;
        align-items: center;
      }
      nav.site-nav a.active { color: var(--ink); border-bottom: 2px solid var(--accent); }

      /* ----- Main + footer ----- */
      main {
        max-width: 1240px;
        margin: 0 auto;
        padding: 32px 20px 80px;
      }
      footer.site {
        max-width: 1240px;
        margin: 0 auto;
        padding: 28px 20px 80px;
        border-top: 1px solid var(--line);
        color: var(--ink-mute);
        font-size: 13px;
      }
      footer.site code { background: var(--bg-sunk); padding: 2px 5px; border-radius: 3px; font-size: 12px; }

      /* ----- Page content elements (rendered markdown) ----- */
      .body-block { color: var(--ink-soft); }
      .body-block p { margin: 0 0 1em; }
      .body-block h2 {
        font-family: ui-serif, Georgia, "Times New Roman", serif;
        font-size: 22px;
        color: var(--ink);
        margin: 32px 0 12px;
        line-height: 1.25;
      }
      .body-block h3 {
        font-family: ui-serif, Georgia, "Times New Roman", serif;
        font-size: 18px;
        color: var(--ink);
        margin: 24px 0 10px;
        line-height: 1.3;
      }
      .body-block ul, .body-block ol { margin: 0 0 1em 1.25em; padding: 0; }
      .body-block li { margin: 0 0 0.35em; }
      .body-block blockquote {
        margin: 1em 0;
        padding: 0 0 0 14px;
        border-left: 3px solid var(--accent);
        color: var(--ink-mute);
        font-style: italic;
      }
      .body-block blockquote p { margin: 0 0 0.5em; }
      .body-block blockquote p:last-child { margin-bottom: 0; }
      .body-block code {
        font-family: ui-monospace, "SF Mono", "Menlo", "Consolas", monospace;
        font-size: 0.9em;
        background: var(--bg-sunk);
        padding: 1px 5px;
        border-radius: 3px;
      }
      .body-block pre {
        margin: 1em 0;
        padding: 14px 16px;
        background: var(--bg-sunk);
        border: 1px solid var(--line);
        border-radius: 6px;
        overflow-x: auto;
        font-size: 13px;
        line-height: 1.5;
      }
      .body-block pre code {
        background: none;
        padding: 0;
        font-size: inherit;
      }
      .body-block table {
        border-collapse: collapse;
        margin: 1em 0;
        font-size: 14px;
        width: 100%;
      }
      .body-block th, .body-block td {
        text-align: left;
        padding: 6px 12px;
        border-bottom: 1px solid var(--line);
      }
      .body-block th { color: var(--ink); font-weight: 600; }
      .body-block strong { color: var(--ink); }
      .body-block em { font-style: italic; }
      .body-block a { color: var(--accent); }

      /* ----- Home / page / post helpers (parity with Next globals.css) ----- */
      .home-h1 {
        font-family: ui-serif, Georgia, serif;
        font-size: clamp(28px, 4vw, 44px);
        line-height: 1.15;
        letter-spacing: -0.01em;
        margin: 0 0 12px;
      }
      .home-tagline { font-size: 18px; color: var(--ink-soft); margin: 0 0 24px; }
      .home-cards {
        list-style: none;
        padding: 0;
        margin: 28px 0 0;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }
      .home-card-link {
        display: inline-block;
        padding: 9px 16px;
        border: 1px solid var(--line);
        border-radius: 8px;
        color: var(--ink);
      }
      .page-h1 {
        font-family: ui-serif, Georgia, serif;
        font-size: clamp(26px, 3.5vw, 36px);
        line-height: 1.2;
        margin: 0 0 12px;
      }
      .page-lede { font-size: 17px; color: var(--ink-soft); margin: 0 0 28px; }

      .post-meta {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--ink-mute);
        font-size: 14px;
        margin: 0 0 28px;
      }
      .post-meta .avatar { flex-shrink: 0; }
      .post-author-card {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        margin-top: 36px;
        padding: 16px;
        background: var(--bg-sunk);
        border-radius: 8px;
        font-size: 14px;
        color: var(--ink-soft);
      }
      .post-author-card .avatar { flex-shrink: 0; }
      .post-author-card .body { flex: 1; min-width: 0; }
      .post-author-card strong { color: var(--ink); }
      .post-author-card .resolved-from {
        margin-top: 6px;
        font-size: 12px;
        color: var(--ink-mute);
        font-family: ui-monospace, monospace;
      }

      .blog-list { list-style: none; padding: 0; margin: 24px 0 0; }
      .blog-list li { padding: 14px 0; border-top: 1px solid var(--line); display: flex; align-items: center; gap: 12px; }
      .blog-list a { display: block; font-size: 17px; color: var(--ink); }
      .blog-list .meta { color: var(--ink-mute); font-size: 13px; margin-top: 4px; }
      .blog-list .avatar { flex-shrink: 0; }
      .blog-list .post-item-text { flex: 1; min-width: 0; }

      .avatar { display: block; border-radius: 50%; }
    </style>
    <style set:html={tokenCss}></style>
    {jsonLd && (
      <script type="application/ld+json" set:html={jsonLd}></script>
    )}
    <script type="application/json" id="mosaic-record" set:html={resolvedJson}></script>
    <script type="application/json" id="mosaic-tree" set:html={treeJson}></script>
  </head>
  <body>
    {banner && (
      <div class="meta-banner">
        <div class="meta-banner-inner">
          <span class="meta-banner-label">META</span>
          <span>
            {banner.text}{' '}
            {banner.linkUrl && <a href={banner.linkUrl}>{banner.linkText ?? 'Learn more'}</a>}
          </span>
        </div>
      </div>
    )}
    <header class="site">
      <div class="nav-inner">
        <a class="brand" href={href('/')}>
          <img src={href('/logo.svg')} alt="" />
          Acme Foundry
        </a>
        <nav class="site-nav">
          {nav.map((item) => (
            <a
              href={href(item.url)}
              class={isActive(item.url) ? 'active' : ''}
            >{item.label}</a>
          ))}
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site">
      Built with <a href="https://astro.build">Astro</a> and the <a href="https://github.com/slavasolutions/mosaic"><code>@ssolu/mosaic-astro</code></a> loader. Each page is a single static HTML file compiled from a folder of JSON. No runtime, no database, no engine.
    </footer>

    <!-- @ssolu/mosaic-devtool inspector — load only when ?debug=1 is in the URL.
         The devtool is a one-line opt-in: paint a tiny gate script that pulls
         the IIFE bundle off the deployed site, no UI shipped unless asked. -->
    <script is:inline define:vars={{ devtoolSrc }}>
      (function () {
        if (location.search.indexOf('debug=1') === -1) return;
        var s = document.createElement('script');
        s.src = devtoolSrc;
        s.defer = true;
        document.head.appendChild(s);
      })();
    </script>
  </body>
</html>
