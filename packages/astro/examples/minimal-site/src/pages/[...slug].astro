---
import { getCollection } from 'astro:content';
import { renderBody } from '@ssolu/mosaic-astro';
import Layout from '../layouts/Layout.astro';
import { renderAvatar } from '../lib/avatar';

export async function getStaticPaths() {
  const entries = await getCollection('pages');
  return entries
    .filter((entry) => typeof entry.data.url === 'string')
    .map((entry) => ({
      params: { slug: entry.data.url.replace(/^\//, '') || undefined },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const data = entry.data as Record<string, any>;
const currentPath = data.url as string;

const isHome = currentPath === '/';
const isBlogIndex = currentPath === '/blog';
const isPost = currentPath.startsWith('/blog/') && !isBlogIndex;

// Surface posts for blog index + home journal preview.
let posts: Array<{ url: string; title: string; publishedAt?: string; authorName?: string }> = [];
if (isBlogIndex || isHome) {
  const all = await getCollection('pages');
  posts = all
    .filter((e) => {
      const u = (e.data as any).url;
      return typeof u === 'string' && u.startsWith('/blog/') && u !== '/blog';
    })
    .map((e) => {
      const d = e.data as Record<string, any>;
      const authorObj = d.author && typeof d.author === 'object' ? d.author : null;
      return {
        url: d.url as string,
        title: (d.title as string) ?? d.slug,
        publishedAt: d.publishedAt as string | undefined,
        authorName: authorObj?.name as string | undefined,
      };
    })
    .sort((a, b) => (b.publishedAt ?? '').localeCompare(a.publishedAt ?? ''));
}
const homePosts = isHome ? posts.slice(0, 3) : [];

const authorObj = data.author && typeof data.author === 'object' ? data.author : null;
const authorDisplay = (authorObj && (authorObj as Record<string, unknown>).display) as
  | string
  | undefined;
const showAuthorAvatar = isPost && authorDisplay !== 'text-only';

const base = (import.meta.env.BASE_URL ?? '/').replace(/\/+$/, '');
function href(p: string): string {
  return base + p;
}

const hasSubPages = Array.isArray(data.subPages) && data.subPages.length > 0;
const hasMembers = Array.isArray(data.members) && data.members.length > 0;
const hasFeatured = Array.isArray(data.featuredWork) && data.featuredWork.length > 0;
const hasHomeLinks = Array.isArray(data.homeLinks) && data.homeLinks.length > 0;
const heroImg = data.hero && typeof data.hero === 'object' ? data.hero : null;
---

<Layout title={`${data.title ?? entry.id}${data.title ? ' — ' : ''}${data.title ? '' : ''}`} currentPath={currentPath} entry={entry}>
  {isHome && (
    <section>
      <div class="home-hero">
        <div class="home-hero-text">
          <h1 class="home-h1">{data.title}</h1>
          {data.tagline && <p class="home-tagline">{data.tagline}</p>}
          {data.intro && <p class="home-intro">{data.intro}</p>}
          {hasHomeLinks && (
            <ul class="home-cards">
              {data.homeLinks.map((link: any, i: number) => (
                <li>
                  <a class={`home-card-link${i === 0 ? ' primary' : ''}`} href={href(link.url)}>{link.label} →</a>
                </li>
              ))}
            </ul>
          )}
        </div>
        {heroImg && heroImg.image && (
          <div class="home-hero-image">
            <img src={heroImg.image} alt={heroImg.alt ?? ''} loading="eager" />
          </div>
        )}
      </div>

      {entry.body && <div class="body-block" set:html={renderBody(entry.body, (entry.data as any).bodyExt)}></div>}

      {hasFeatured && (
        <div class="home-section">
          <p class="section-eyebrow">Selected work</p>
          <h2 class="section-h2">What we do.</h2>
          <ul class="featured-grid">
            {data.featuredWork.map((card: any) => (
              <li>
                <a class="featured-card" href={href(card.url)}>
                  {card.image && <img src={card.image} alt="" loading="lazy" />}
                  <div class="featured-card-body">
                    <h3>{card.title}</h3>
                    {card.summary && <p>{card.summary}</p>}
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      {homePosts.length > 0 && (
        <div class="home-section">
          <p class="section-eyebrow">Journal</p>
          <h2 class="section-h2">Recent writing.</h2>
          <ul class="journal-preview">
            {homePosts.map((post) => (
              <li>
                <a href={href(post.url)}>
                  <span class="jp-title">{post.title}</span>
                  <span class="jp-meta">
                    {post.publishedAt}{post.authorName ? ` · ${post.authorName}` : ''}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>
  )}

  {!isHome && !isPost && (
    <section>
      <h1 class="page-h1">{data.title}</h1>
      {data.lede && <p class="page-lede">{data.lede}</p>}
      {heroImg && heroImg.image && (
        <img class="hero-img" src={heroImg.image} alt={heroImg.alt ?? ''} loading="lazy" />
      )}
      {data.image && typeof data.image === 'string' && (
        <img class="hero-img" src={data.image} alt={data.imageAlt ?? ''} loading="lazy" />
      )}

      {entry.body && <div class="body-block" set:html={renderBody(entry.body, (entry.data as any).bodyExt)}></div>}

      {hasSubPages && (
        <ul class="subpage-grid">
          {data.subPages.map((sp: any) => (
            <li><a href={href(sp.url)}><strong>{sp.title}</strong></a></li>
          ))}
        </ul>
      )}

      {hasMembers && (
        <ul class="subpage-grid">
          {data.members.map((m: any) => {
            const name = typeof m === 'object' ? (m.name ?? m.title ?? '') : '';
            const role = typeof m === 'object' ? (m.role ?? '') : '';
            return (
              <li>
                <a href="#" style="pointer-events:none;cursor:default;">
                  <strong>{name}</strong>
                  {role && <div style="color:var(--ink-mute);font-size:13px;margin-top:4px;">{role}</div>}
                </a>
              </li>
            );
          })}
        </ul>
      )}

      {data['@type'] === 'ContactPage' && data.email && (
        <div style="margin-top:24px;padding:16px;background:var(--bg-sunk);border-radius:8px;font-size:14px;">
          <div><strong>Email:</strong> <a href={`mailto:${data.email}`}>{data.email}</a></div>
          {data.phone && <div style="margin-top:6px;"><strong>Phone:</strong> {data.phone}</div>}
          {data.address && typeof data.address === 'object' && (
            <div style="margin-top:6px;">
              <strong>Address:</strong>{' '}
              {[data.address.line1, data.address.city, data.address.postcode, data.address.country].filter(Boolean).join(', ')}
            </div>
          )}
          {Array.isArray(data.hours) && (
            <table style="margin-top:14px;border-collapse:collapse;width:100%;">
              <tbody>
                {data.hours.map((h: any) => (
                  <tr>
                    <th style="text-align:left;padding:4px 12px 4px 0;font-weight:600;color:var(--ink);">{h.days}</th>
                    <td style="padding:4px 0;">{h.hours}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>
      )}

      {isBlogIndex && (
        <ul class="blog-list">
          {posts.map((post) => (
            <li>
              <div class="post-item-text">
                <a href={href(post.url)}>{post.title}</a>
                <div class="meta">
                  {post.publishedAt}{post.authorName ? ` · ${post.authorName}` : ''}
                </div>
              </div>
            </li>
          ))}
        </ul>
      )}
    </section>
  )}

  {isPost && (
    <article>
      <h1 class="page-h1">{data.title}</h1>
      <div class="post-meta">
        {showAuthorAvatar && authorObj && (
          <span class="avatar" set:html={renderAvatar(authorObj.name, 32)}></span>
        )}
        <span>
          {data.publishedAt}{authorObj ? ` · by ${authorObj.name}` : ''}
          {authorObj?.role && ` (${authorObj.role})`}
        </span>
      </div>
      {heroImg && heroImg.image && (
        <img class="hero-img" src={heroImg.image} alt={heroImg.alt ?? ''} loading="lazy" />
      )}
      {entry.body && <div class="body-block" set:html={renderBody(entry.body, (entry.data as any).bodyExt)}></div>}
      {authorObj?.bio && (
        <div class="post-author-card">
          {showAuthorAvatar && (
            <span class="avatar" set:html={renderAvatar(authorObj.name, 48)}></span>
          )}
          <div class="body">
            <strong>About {authorObj.name}</strong> — {authorObj.bio}
          </div>
        </div>
      )}
    </article>
  )}
</Layout>
