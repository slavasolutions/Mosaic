---
import { getCollection } from 'astro:content';
import { renderBody } from '@ssolu/mosaic-astro';
import Layout from '../layouts/Layout.astro';
import { renderAvatar } from '../lib/avatar';

export async function getStaticPaths() {
  const entries = await getCollection('pages');
  return entries
    .filter((entry) => typeof entry.data.url === 'string')
    .map((entry) => ({
      params: { slug: entry.data.url.replace(/^\//, '') || undefined },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const data = entry.data as Record<string, any>;
const currentPath = data.url as string;

// For the blog index, surface the list of sibling posts.
const isBlogIndex = currentPath === '/blog';
let posts: Array<{ url: string; title: string; publishedAt?: string; authorName?: string }> = [];
if (isBlogIndex) {
  const all = await getCollection('pages');
  posts = all
    .filter((e) => {
      const u = (e.data as any).url;
      return typeof u === 'string' && u.startsWith('/blog/') && u !== '/blog';
    })
    .map((e) => {
      const d = e.data as Record<string, any>;
      const authorObj = d.author && typeof d.author === 'object' ? d.author : null;
      return {
        url: d.url as string,
        title: (d.title as string) ?? d.slug,
        publishedAt: d.publishedAt as string | undefined,
        authorName: authorObj?.name as string | undefined,
      };
    })
    .sort((a, b) => (b.publishedAt ?? '').localeCompare(a.publishedAt ?? ''));
}

const isPost = currentPath.startsWith('/blog/') && !isBlogIndex;
const authorObj = data.author && typeof data.author === 'object' ? data.author : null;
// `display` cascades from `mosaic.json#defaults.author.display` (or any
// `defaults` block above the record). `text-only` suppresses every avatar
// SVG. Default is `with-avatar`. The blog index never shows avatars
// regardless — the author identity matters at the post, not the list.
const authorDisplay = (authorObj && (authorObj as Record<string, unknown>).display) as
  | string
  | undefined;
const showAuthorAvatar = isPost && authorDisplay !== 'text-only';

const base = (import.meta.env.BASE_URL ?? '/').replace(/\/+$/, '');
function href(p: string): string {
  return base + p;
}
---

<Layout title={data.title ?? entry.id} currentPath={currentPath} entry={entry}>
  {currentPath === '/' && (
    <section>
      <h1 class="home-h1">{data.title}</h1>
      {data.tagline && <p class="home-tagline">{data.tagline}</p>}
      {data.intro && <p>{data.intro}</p>}
      {Array.isArray(data.homeLinks) && (
        <ul class="home-cards">
          {data.homeLinks.map((link: any) => (
            <li>
              <a class="home-card-link" href={href(link.url)}>{link.label} →</a>
            </li>
          ))}
        </ul>
      )}
    </section>
  )}

  {currentPath !== '/' && !isPost && (
    <section>
      <h1 class="page-h1">{data.title}</h1>
      {data.lede && <p class="page-lede">{data.lede}</p>}

      {entry.body && <div class="body-block" set:html={renderBody(entry.body, (entry.data as any).bodyExt)}></div>}

      {isBlogIndex && (
        <ul class="blog-list">
          {posts.map((post) => (
            <li>
              <a href={href(post.url)}>{post.title}</a>
              <div class="meta">
                {post.publishedAt}{post.authorName ? ` · ${post.authorName}` : ''}
              </div>
            </li>
          ))}
        </ul>
      )}
    </section>
  )}

  {isPost && (
    <article>
      <h1 class="page-h1">{data.title}</h1>
      <div class="post-meta">
        {showAuthorAvatar && authorObj && (
          <span class="avatar" set:html={renderAvatar(authorObj.name, 32)}></span>
        )}
        <span>
          {data.publishedAt}{authorObj ? ` · by ${authorObj.name}` : ''}
          {authorObj?.role && ` (${authorObj.role})`}
        </span>
      </div>
      {entry.body && <div class="body-block" set:html={renderBody(entry.body, (entry.data as any).bodyExt)}></div>}
      {authorObj?.bio && (
        <div class="post-author-card">
          {showAuthorAvatar && (
            <span class="avatar" set:html={renderAvatar(authorObj.name, 48)}></span>
          )}
          <div class="body">
            <strong>About {authorObj.name}</strong> — {authorObj.bio}
          </div>
        </div>
      )}
    </article>
  )}
</Layout>
