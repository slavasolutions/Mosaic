---
import type { JournalPreviewBlock } from '@ssolu/mosaic-astro';
interface Props { block: JournalPreviewBlock }
const { block } = Astro.props;
---

<section>
  <div class="wrap">
    {block.eyebrow && <p class="eyebrow">{block.eyebrow}</p>}
    <h2 class="section-h2">{block.heading}</h2>
    <ul class="journal-list">
      {block.items.map((item) => (
        <li>
          <a class="journal-item" href={item.href}>
            <span class="journal-title">{item.title}</span>
            <span class="journal-date">{item.date}</span>
          </a>
        </li>
      ))}
    </ul>
    {block.viewAllHref && (
      <p class="journal-all">
        <a href={block.viewAllHref}>{block.viewAllLabel ?? 'View all'} →</a>
      </p>
    )}
  </div>
</section>

<style>
.journal-list { list-style: none; padding: 0; margin: 0 0 var(--space-5); }
.journal-item {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: var(--space-4);
  padding: var(--space-4) 0;
  border-top: 1px solid var(--color-line);
  font-family: var(--font-display);
  font-weight: 500;
}
.journal-list li:last-child .journal-item { border-bottom: 1px solid var(--color-line); }
.journal-title { color: var(--color-ink); font-size: var(--type-h3); }
.journal-date  { color: var(--color-ink-mute); font-family: var(--font-mono); font-size: var(--type-mono); }
.journal-all   { font-family: var(--font-mono); font-size: var(--type-small); color: var(--color-accent); }
</style>
